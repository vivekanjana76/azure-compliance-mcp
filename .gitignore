.env
.env.*
.envrc
*.pem
*.key

# Testing / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# Type checkers / linters
.mypy_cache/
.pyre/
.pytype/
.ruff_cache/

# IDE / editor
.idea/
.vscode/
*.swp

# Claude Code local (personal) settings
.claude/settings.local.json

# OS
.DS_Store
Thumbs.db

# Jupyter
.ipynb_checkpoints/

